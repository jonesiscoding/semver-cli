#!/bin/bash

padding="----------------------------------------------------------------------------"
selfDir="$( cd "$(dirname "${BASH_SOURCE[0]}")" || exit 1 ; pwd -P )"
selfLib="$selfDir/lib"
selfOut="$selfDir/../dist"
[ ! -f "$selfLib" ] && mkdir -p "$selfLib"
[ ! -f "$selfOut" ] && mkdir -p "$selfOut"
[ ! -f "$selfLib/inline.sh" ] && curl -s -o "$selfLib/inline.sh" https://raw.githubusercontent.com/carlocorradini/inline/main/inline.sh && chmod 755 "$selfLib/inline.sh"
fileScripts=("$selfDir/../src/semver")

if [[ "$OSTYPE" == "darwin"* ]]; then
  # macOS (BSD sed) requires '' after -i
  xSED=(sed -i '')
else
  xSED=(sed -i)
fi

## region ###################################### Functions

# shellcheck source=../src/lib/_out.sh
source "$selfDir/../src/lib/_in.sh"
source "$selfDir/../src/lib/_out.sh"

function script::build() {
  local inFile outFile  placeholder outVersion

  inFile="$1"
  outFile="$2"
  outVersion="${3-:1.0}"
  placeholder="${4:-##VERSION##}"

  if ! cronic "$selfLib/inline.sh" --in-file "$inFile" --out-file "$outFile"; then
    return 1
  fi

  "${xSED[@]}" -e "1 s/$placeholder/$outVersion/; t" -e "1,// s//$outVersion/" "$outFile"

  chmod 755 "$outFile"
}

function script::metadata() {
  local tFile tRev tDate tUser

  tFile="$1"
  tRev="${2}"
  tDate="${3}"
  tUser="${4:-$USER}"

  if [ -f "$tFile" ]; then
    if [ -n "$tRev" ]; then
      "${xSED[@]}" "s/# @revision$/# @revision $tRev/" "$tFile"
    fi

    if [ -n "$versionOut" ]; then
      "${xSED[@]}" "s/# @version/# @version $versionOut/" "$tFile"
    fi

    if [ -n "$tDate" ]; then
      if [ -n "$tUser" ]; then
        "${xSED[@]}" "s/# @built$/# @built $tDate ($tUser)/" "$tFile"
        "${xSED[@]}" "s/# @uploaded$/# @built $tDate ($tUser)/" "$tFile"
      else
        "${xSED[@]}" "s/# @built$/# @built $tDate/" "$tFile"
        "${xSED[@]}" "s/# @uploaded$/# @uploaded $tDate/" "$tFile"
      fi
    fi
  fi
}

## endregion ################################### Functions

## region ###################################### Main Code

versionOut="$1"
echo "Handling Scripts..." | out
for file in "${fileScripts[@]}"
do
  filename=$(basename "$file")
  echo "  Processing $file" | default | out
  if [ ! -f "$file" ]; then
    echo "  ERROR: File does not exist!" | error | out
    exit 1
  else
    fileOut="$selfOut/$filename"
    [ -f "$fileOut" ] && rm "$fileOut"
    echo "   Building $filename" | notify
    if ! script::build "$file" "$fileOut" "$versionOut" ; then
      exit 1
    fi
    ! $flagV && echo "DONE" | success | badge

    echo "   Adding Metadata to $filename" | notify
    rev=$(git log -n 1  --pretty="format:%h (%ai)" -- "$file")
    date=$(date +"%Y-%m-%d %H:%M:%S %z")
    if ! script::metadata "$fileOut" "$rev" "$date" "$USER"; then
      echo "ERROR" | error | badge
      exit 1
    fi
    ! $flagV && echo "DONE" | success | badge
  fi
done
