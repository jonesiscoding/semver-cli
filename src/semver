#!/bin/bash

# @file semver
# @brief Parses, increments, and formats semantic version numbers.
# @option --quiet           Quiet Output
# @option --verbose         Verbose Output
# @option -h | --help       Show Help
# @option --os              In macOS, use current OS version for input version
# @option --git             Use git tags for input version
# @option --json            Output as JSON object
# @option --yaml            Output as YAML object
# @option --format <format> Format full version number with given string
# @option -c                Compact Output
# @option -r                Raw Output
# @option --major Increment Major Version
# @option --minor Increment Minor Version
# @option --patch | --rev   Increment Patch/Revision Version
# @arg $1 string            Input Version
# @arg $2 string            JQ-Style Filters
# @exitcode 0               Success
# @exitcode 1               Error
# @exitcode 2               Invalid Option
# @exitcode 3               Missing JQ
# @exitcode 4               Missing YQ; used --yaml flag
# @exitcode 5               Missing git; used --git flag
# @exitcode 10              Not in Git Repo; used --git flag
#
# @license
#
#   Copyright 2026-04 AMJones <am@jonesiscoding.com>
#
